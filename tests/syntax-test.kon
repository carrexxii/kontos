(**********************************************************************)

type Vec3 is
	{ x of real;
	  y of real;
	  z of real }
	as string =
		"({this.x}, {this.y}, {this.z})"

type Colour is
	| Red
    | Green
	| Blue
	as string =
		| Red   => "Red"
		| Green => "Green"
		| Blue  => "Blue"
	as Vec3 =
		| Red   => { x = 1.0; y = 0.0; z = 0.0 }
		| Green => { x = 0.0; y = 1.0; z = 0.0 }
		| Blue  => { x = 0.0; y = 0.0; z = 1.0 }

type Option of a is Some of a | None
type Result of a b is Ok of a | Error of b
