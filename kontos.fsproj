<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <FsLexToolExe>fslex.dll</FsLexToolExe>
    <FsYaccToolExe>fsyacc.dll</FsYaccToolExe>
    <FsYaccOutputFolder>src/</FsYaccOutputFolder>
    <FsLexOutputFolder>src/</FsLexOutputFolder>
  </PropertyGroup>
  <ItemGroup>
    <FsYacc Include="parser.fsy">
      <OtherFlags>--module Parser</OtherFlags>
    </FsYacc>
    <FsLex Include="lexer.fsl">
      <OtherFlags>--module Lexer --unicode</OtherFlags>
    </FsLex>
    <Compile Include="src/ast.fs" />
    <Compile Include="src/bytecode.fs" />
    <Compile Include="src/parser.fsi" />
    <Compile Include="src/parser.fs" />
    <Compile Include="src/lexer.fs" />
    <Compile Include="src/main.fs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FSLexYacc" Version="11.*" />
    <PackageReference Include="FsLexYacc.Runtime" Version="11.*" />
  </ItemGroup>
</Project>